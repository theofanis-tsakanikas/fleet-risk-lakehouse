# ==============================================================================
# ☁️ Cloud Data Platform - Environment Configuration Template
# ==============================================================================
# INSTRUCTIONS:
# 1. This file is tracked by Git. Do NOT put real secrets here!
# 2. Copy this file to create your local .env: cp .env.example .env
# 3. Fill in your real credentials in the .env file.
# ==============================================================================

# === ☁️ AWS CREDENTIALS (Admin User Access Keys) ===
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=eu-central-1
DATA_LAKE_BUCKET=dbx-data-lake-bucket
S3_FOLDER_WATCHES=landing-zone/watches
S3_FOLDER_TRACKERS=landing-zone/trackers

# === 🏢 DATABRICKS ACCOUNT (Ready for Terraform) ===
TF_VAR_databricks_account_id=your_databricks_account_id
TF_VAR_databricks_client_id=your_databricks_client_id
TF_VAR_databricks_client_secret=your_databricks_client_secret
DATABRICKS_CLIENT_ID=your_databricks_client_id
DATABRICKS_CLIENT_SECRET=your_databricks_client_secret
DATABRICKS_HOST=https://your-databricks-instance.cloud.databricks.com

# === 🧪 LOCAL DEVELOPMENT CONFIGURATION ===
WATCHES_LOCAL_DIR=data/temp/watches
TRACKERS_LOCAL_DIR=data/temp/trackers

# ==============================================================================
# ⌚ SMARTWATCHES PIPELINE CONFIGURATION (wearables_dev)
# ==============================================================================
WATCHES_CATALOG=wearables_dev

# --- Metadata & Checkpoints ---
WATCHES_METADATA_SCHEMA=metadata
WATCHES_CHECKPOINT_VOLUME=checkpoints

# --- Bronze Layer ---
WATCHES_BRONZE_SCHEMA=bronze
WATCHES_BRONZE_VOLUME=raw_files
WATCHES_BRONZE_TABLE=watches_raw

# --- Silver Layer ---
WATCHES_SILVER_SCHEMA=silver
WATCHES_SILVER_TABLE=watches_clean

# ==============================================================================
# 📍 IOT TRACKERS PIPELINE CONFIGURATION (trackers_dev)
# ==============================================================================
TRACKERS_CATALOG=trackers_dev

# --- Metadata & Checkpoints ---
TRACKERS_METADATA_SCHEMA=metadata
TRACKERS_CHECKPOINT_VOLUME=checkpoints

# --- Bronze Layer ---
TRACKERS_BRONZE_SCHEMA=bronze
TRACKERS_BRONZE_VOLUME=raw_files
TRACKERS_BRONZE_TABLE=trackers_raw

# --- Silver Layer ---
TRACKERS_SILVER_SCHEMA=silver
TRACKERS_SILVER_TABLE=trackers_clean

# ==============================================================================
# 🏆 UNIFIED FLEET GOLD LAYER (fleet_dev)
# ==============================================================================
GOLD_CATALOG=fleet_dev
GOLD_SCHEMA=operations

# --- Gold Tables ---
GOLD_LIVE_TABLE=fleet_live_status
GOLD_METRICS_TABLE=driver_safety_metrics
GOLD_ALERTS_TABLE=fleet_safety_alerts

# --- Metadata & Checkpoints for Gold ---
GOLD_METADATA_SCHEMA=metadata
GOLD_CHECKPOINT_VOLUME=checkpoints